{
  "name": "a2ui-tamagotchi",
  "version": "1.0.0",
  "description": "Agent-driven Tamagotchi virtual pet with generative UI",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"tsx watch server/index.ts\" \"vite\"",
    "dev:server": "tsx watch server/index.ts",
    "dev:client": "vite",
    "build": "tsc --project tsconfig.json && vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "@google/generative-ai": "^0.21.0",
    "@tailwindcss/postcss": "^4.3.0",
    "cors": "^2.8.5",
    "express": "^4.21.0",
    "nes.css": "^2.2.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tw-animate-css": "^1.4.0",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vite": "^6.0.3"
  }
}
