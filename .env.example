# Copy to `.env.local` (see docs/API_KEYS.md)

# LLM — Google Gemini (BuiltInAgent / Vercel AI SDK)
GOOGLE_API_KEY=
# GEMINI_API_KEY=

# Model: full provider/id or shorthand (e.g. gemini-2.5-flash)
# For future Gemini 3.x IDs from Google AI Studio, set e.g. LLM_MODEL=google/gemini-3.1-pro
LLM_MODEL=google/gemini-2.5-flash

# Maps (browser)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Optional
# COPILOTKIT_TELEMETRY_DISABLED=true
