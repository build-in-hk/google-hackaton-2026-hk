# Copy to `.env.local` (see docs/API_KEYS.md)

# Agent LLM — Google Gemini API (Google AI Studio)
GOOGLE_API_KEY=
# GEMINI_API_KEY=

# Model: full provider/model or shorthand (e.g. gemini-2.5-flash)
LLM_MODEL=google/gemini-2.5-flash

# Maps (browser; separate from the LLM key)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Optional
# COPILOTKIT_TELEMETRY_DISABLED=true
